<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".ui.MainActivity">
    
    <!-- 灵动岛预览区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="80dp">
        
        <!-- 状态卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <!-- 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DynamicOasis"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="灵动岛 · 澎湃OS适配版"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
                
                <!-- 主开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="启用灵动岛"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/mainSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                    
                </LinearLayout>
                
                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider" />
                
                <!-- 服务状态 -->
                <LinearLayout
                    android:id="@+id/serviceStatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <View
                        android:id="@+id/serviceStatusIndicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_indicator_offline" />
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="服务状态"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                    
                    <TextView
                        android:id="@+id/serviceStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已停止"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    
                </LinearLayout>
                
                <!-- 权限状态 -->
                <LinearLayout
                    android:id="@+id/permissionStatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <View
                        android:id="@+id/permissionStatusIndicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_indicator_warning" />
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="权限状态"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                    
                    <TextView
                        android:id="@+id/permissionStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击检查"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                    
                </LinearLayout>
                
            </LinearLayout>
            
        </com.google.android.material.card.MaterialCardView>
        
        <!-- 快捷功能 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能开关"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:textAllCaps="true" />
                
                <!-- 充电提示 -->
                <include layout="@layout/item_setting_row"
                    android:id="@+id/settingCharging" />
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_charging"
                        app:tint="@color/color_primary" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="充电状态提示"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
                
                <!-- 低电量 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_battery_low"
                        app:tint="@color/color_warning" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="低电量提示"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
                
                <!-- 网络 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/color_blue" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="网络状态提示"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
                
                <!-- 通知 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/color_secondary" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="通知消息提示"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
                
                <!-- 闹钟 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_alarm"
                        app:tint="@color/color_alarm" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="闹钟提示"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
                
            </LinearLayout>
            
        </com.google.android.material.card.MaterialCardView>
        
    </LinearLayout>
    
    <!-- 设置按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/settingsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_settings"
        app:tint="@color/white"
        app:backgroundTint="@color/color_primary" />
    
    <!-- 模拟灵动岛预览 -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="50dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="48dp"
        android:background="@drawable/island_background"
        android:elevation="8dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_idle"
                app:tint="@color/white" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="● 灵动岛"
                android:textColor="@color/white"
                android:textSize="14sp" />
            
        </LinearLayout>
        
    </FrameLayout>
    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/settingsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    
</FrameLayout>
